# Fireworks AI API Key (runs Gemma 3 on AMD GPU infrastructure)
# Get yours at: https://fireworks.ai → API Keys
# The app runs in demo mode without this key — add it for live AI
FIREWORKS_API_KEY=fw_your_key_here

# Optional: Google Business Profile API (for real review fetching)
# Leave blank for demo mode with sample data
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
